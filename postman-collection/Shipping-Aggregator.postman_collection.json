          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let response = pm.response.json();",
                  "",
                  "if (pm.response.code === 200) {",
                  "    if (response.shipmentIds && response.shipmentIds.length > 0) {",
                  "        pm.environment.set(\"shipment_id\", response.shipmentIds[0]);",
                  "        pm.execution.setNextRequest(\"Pack\");",
                  "    } else {",
                  "        console.log(\"No shipment IDs returned:\", response.messages);",
                  "        pm.execution.setNextRequest(null);",
                  "    }",
                  "}"
                ],
