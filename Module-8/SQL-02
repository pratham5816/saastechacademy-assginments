# SQL-ASSIGNMENT-02

## Q5.1 Shipping Addresses for October 2023 Orders

```sql
SELECT OH.ORDER_ID,
ORDR.PARTY_ID,
P.first_name AS CUSTOMER_NAME,
PA.ADDRESS1 AS STREET_ADDRESS,
PA.CITY,
PA.STATE_PROVINCE_GEO_ID,
PA.POSTAL_CODE,
PA.COUNTRY_GEO_ID AS COUNTRY_CODE,
OH.STATUS_ID AS ORDER_STATUS,
OH.ORDER_DATE
FROM ORDER_HEADER OH
JOIN order_contact_mech OCM ON OH.order_id = OCM.order_id
AND OCM.CONTACT_MECH_PURPOSE_TYPE_ID = 'SHIPPING_LOCATION'
JOIN postal_address PA ON PA.CONTACT_MECH_ID = OCM.CONTACT_MECH_ID
JOIN ORDER_ROLE ORDR ON OH.order_id = ORDR.order_id
AND ORDR.ROLE_TYPE_ID = 'PLACING_CUSTOMER'
JOIN PERSON P ON P.PARTY_ID = ORDR.PARTY_ID
WHERE OH.ORDER_DATE > "2023-9-30"
AND OH.ORDER_DATE < "2023-11-1";
```

## Q5.2 Orders from New York

```sql
SELECT OH.order_id,
CONCAT(P.FIRST_NAME, " " ,P.LAST_NAME) as CUSTOMER_NAME,
PA.STATE_PROVINCE_GEO_ID AS STATE_PROVINCE,
PA.ADDRESS1 as STREET_NAME ,
PA.CITY,
PA.POSTAL_CODE,
OH.GRAND_TOTAL AS TOTAL_AMOUNT,
OH.ORDER_DATE,
OH.STATUS_ID as ORDER_STATUS
FROM order_header OH
JOIN order_contact_mech OCM ON OH.ORDER_ID = OCM.ORDER_ID
AND OCM.CONTACT_MECH_PURPOSE_TYPE_ID = 'SHIPPING_LOCATION'
JOIN postal_address PA ON PA.CONTACT_MECH_ID = OCM.CONTACT_MECH_ID
JOIN ORDER_ROLE ORR ON OH.ORDER_ID = ORR.ORDER_ID
AND ORR.ROLE_TYPE_ID ='PLACING_CUSTOMER'
JOIN PERSON P ON ORR.PARTY_ID = P.PARTY_ID
WHERE PA.STATE_PROVINCE_GEO_ID = 'NY';
```

## Q5.3 Top-Selling Product in New York

```sql
SELECT OI.PRODUCT_ID,
P.INTERNAL_NAME,
PA.CITY,
SUM(OI.QUANTITY) AS TOTAL_QUANTITY_SOLD,
SUM(OI.QUANTITY * OI.UNIT_PRICE) AS REVENUE
FROM order_header OH
JOIN ORDER_ITEM OI ON OH.ORDER_ID = OI.ORDER_ID
JOIN PRODUCT P ON OI.PRODUCT_ID = P.PRODUCT_ID
JOIN ORDER_CONTACT_MECH OCM ON OI.ORDER_ID = OCM.ORDER_ID
AND OCM.CONTACT_MECH_PURPOSE_TYPE_ID ='SHIPPING_LOCATION'
JOIN postal_address PA ON OCM.CONTACT_MECH_ID = PA.CONTACT_MECH_ID
WHERE PA.STATE_PROVINCE_GEO_ID = 'NY'
GROUP BY OI.PRODUCT_ID,
P.INTERNAL_NAME,
PA.CITY,
PA.STATE_PROVINCE_GEO_ID ORDER BY TOTAL_QUANTITY_SOLD DESC;
```

## Q8.1 Lost and Damaged Inventory

```sql
SELECT I.INVENTORY_ITEM_ID,
I.PRODUCT_ID,
I.FACILITY_ID,
IIV.REASON_ENUM_ID,
IIV.QUANTITY_ON_HAND_VAR AS QUANTITY_LOST_OR_DAMAGED,
IIV.LAST_UPDATED_TX_STAMP AS TRANSACTION_DATE
FROM inventory_item I
JOIN inventory_item_variance IIV ON I.INVENTORY_ITEM_ID = IIV.INVENTORY_ITEM_ID
WHERE IIV.REASON_ENUM_ID IN ("VAR_DAMAGED",
"VAR_STOLEN" ,
"REJ_RSN_DAMAGED");
```

## Q8.2 Low Stock or Out of Stock Items Report

```sql
SELECT II.PRODUCT_ID,
P.PRODUCT_NAME,
II.FACILITY_ID,
II.AVAILABLE_TO_PROMISE_TOTAL AS ATP,
II.QUANTITY_ON_HAND_TOTAL AS QOH,
CURRENT_TIMESTAMP() AS DATE_CHECKED,
PF.MINIMUM_STOCK - II.QUANTITY_ON_HAND_TOTAL AS REORDER_THRESHOLD
FROM inventory_item II
JOIN product P ON P.product_id = II.product_id
JOIN product_facility PF ON PF.PRODUCT_ID = II.PRODUCT_ID
AND PF.facility_id = II.FACILITY_ID
WHERE II.QUANTITY_ON_HAND_TOTAL = 0
OR (II.QUANTITY_ON_HAND_TOTAL < PF.MINIMUM_STOCK);
```

## Q8.3 Retrieve the Current Facility (Physical or Virtual) of Open Orders

```sql
SELECT OS.order_id,
OS.STATUS_ID,
OISG.FACILITY_ID,
F.FACILITY_NAME ,
F.FACILITY_TYPE_ID
FROM ORDER_STATUS OS
JOIN order_item_ship_group OISG ON OS.order_ID = OISG.ORDER_ID
JOIN facility F ON OISG.facility_id = F.FACILITY_ID
WHERE OS.STATUS_ID IN ('ORDER_HOLD',
'ORDER_CREATED',
'ORDER_APPROVED');
```

## Q8.4 Items Where QOH and ATP Differ

```sql
SELECT II.product_id,
II.FACILITY_ID,
II.QUANTITY_ON_HAND_TOTAL AS QOH,
II.AVAILABLE_TO_PROMISE_TOTAL AS ATP,
ABS(II.QUANTITY_ON_HAND_TOTAL - II.AVAILABLE_TO_PROMISE_TOTAL) AS DIFFERENCE
FROM inventory_item II
WHERE II.AVAILABLE_TO_PROMISE_TOTAL <> II.QUANTITY_ON_HAND_TOTAL;
```

## Q8.5 Order Item Current Status Changed Date-Time

```sql
SELECT OI.ORDER_ID,
OI.ORDER_ITEM_SEQ_ID,
OI.STATUS_ID as CURRENT_STATUS_ID,
OI.LAST_UPDATED_STAMP as STATUS_CHANGE_DATETIME,
OI.CHANGE_BY_USER_LOGIN_ID
FROM order_item OI;
```

## Q8.6 Total Orders by Sales Channel

```sql
SELECT OH.SALES_CHANNEL_ENUM_ID,
COUNT(OH.ORDER_ID) ,
SUM(OH.GRAND_TOTAL)
FROM ORDER_HEADER OH
GROUP BY OH.SALES_CHANNEL_ENUM_ID;
```

